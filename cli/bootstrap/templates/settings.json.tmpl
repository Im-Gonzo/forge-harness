{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_forge": "Generated by Forge {{FORGE_VERSION}} (profile {{PROFILE}}) at {{GENERATED_AT}}. RENDERER CONTRACT: each Stop hook block below carries exactly one command placeholder; when that variable is empty the renderer DROPS the whole block (it must not emit a block whose command is \"\"). With both typecheck vars empty the Stop array renders as []. Merged additively with any existing settings.json — never replaces it.",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/id_rsa)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "_forge_when": "{{TYPECHECK_CMD}}",
        "hooks": [
          {
            "type": "command",
            "command": "{{TYPECHECK_CMD}}",
            "timeout": 120
          }
        ]
      },
      {
        "_forge_when": "{{FE_TYPECHECK_CMD}}",
        "hooks": [
          {
            "type": "command",
            "command": "{{FE_TYPECHECK_CMD}}",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
